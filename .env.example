# Environment Variables — ZQ Master Bridge
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real values

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------

# Log level: debug | info | warn | error
ZQ_LOG_LEVEL=info

# Maximum number of concurrent agents
ZQ_MAX_CONCURRENCY=16

# ------------------------------------------------------------------
# AI / LLM provider (optional — for real agent responses)
# ------------------------------------------------------------------

# OpenAI-compatible API base URL (leave blank to use Tauri echo backend)
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_BASE=

# Your API key — never commit this!
OPENAI_API_KEY=

# Default model name
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

# Path to the SQLite database file (relative to project root)
ZQ_DB_PATH=zq.db

# ------------------------------------------------------------------
# Agent sidecar
# ------------------------------------------------------------------

# Heartbeat interval in seconds
ZQ_HEARTBEAT_INTERVAL=5

# Bind address for the agent HTTP server (if enabled in V3)
ZQ_AGENT_HOST=127.0.0.1
ZQ_AGENT_PORT=8765

# ------------------------------------------------------------------
# Tauri / Vite (dev)
# ------------------------------------------------------------------

# Set to 1 to enable source maps and disable minification
TAURI_DEBUG=0
