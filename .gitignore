# ZQ Master Bridge — .gitignore
# =========================================================

# -----------------------------------------------
# Secrets — NEVER commit these
# -----------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/

# -----------------------------------------------
# Node / npm
# -----------------------------------------------
node_modules/
dist/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# -----------------------------------------------
# Rust / Cargo
# -----------------------------------------------
src-tauri/target/
Cargo.lock.bak

# -----------------------------------------------
# Tauri build outputs
# -----------------------------------------------
src-tauri/gen/
*.app
*.AppImage
*.deb
*.rpm
*.dmg
*.exe
*.msi
*.nsis

# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# -----------------------------------------------
# SQLite databases
# -----------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------
# OS artefacts
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------
# Editor artefacts
# -----------------------------------------------
.idea/
*.swp
*.swo
*~

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/

# -----------------------------------------------
# Temporary files
# -----------------------------------------------
tmp/
temp/
.tmp/
